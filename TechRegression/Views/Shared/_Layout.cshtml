<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TechRegression</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TechRegression.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="site-wrapper">
        <header class="site-navigation">
            <div class="nav-container">
                <a class="nav-logo" asp-controller="Home" asp-action="Index">TechRegression</a>

                <button class="menu-toggle" id="menuToggle" aria-label="Otwórz menu">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>

                <nav class="nav-links" id="navLinks">
                    @if (Context.Session.GetString("AdminLoggedIn") == "true")
                    {
                        <a asp-controller="Articles" asp-action="Create">+ Artykuł</a>
                        <a asp-controller="Categories" asp-action="Index">Kategorie</a>
                        <a asp-controller="Admin" asp-action="Logout" class="logout-link">Wyloguj</a>
                    }
                    else
                    {
                        <a asp-controller="Admin" asp-action="Login">Panel Admina</a>
                    }
                </nav>
            </div>
        </header>

        <main class="container">
            @RenderBody()
        </main>

        <footer class="site-footer">
            <div class="footer-container">
                <div>&copy; 2026 Szymon Moskwa</div>
                <a asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
            </div>
        </footer>
    </div>

    <button id="backToTop" class="back-to-top" title="Przewiń w górę">&uarr;</button>

    <div id="system-clock" class="terminal-clock">00:00</div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
