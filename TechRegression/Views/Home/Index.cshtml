@model IEnumerable<TechRegression.Models.Article>

@{
    ViewData["Title"] = "TechRegression - tech newsy";
    var categories = Model.Where(a => a.Category != null)
                          .Select(a => a.Category)
                          .GroupBy(c => c.Id)
                          .Select(g => g.First())
                          .ToList();
}

<header class="main-hero">
    <h1>TechRegression</h1>
    <p>Najnowsze wieści ze świata technologii, które sprawiają, że chcesz powrócić do epoki brązu</p>
</header>

<main class="news-feed">
    @if (!Model.Any())
    {
        <div class="no-articles">
            <p><i>Brak arykułów</i></p>
        </div>
    }
    else
    {
        @if (categories.Any())
        {
            <div class="filter-bar">
                <button class="filter-btn active" data-category="all">Wszystkie</button>
                @foreach (var cat in categories)
                {
                    <button class="filter-btn" data-category="@cat.Id">@cat.Name</button>
                }
            </div>
        }

        <div class="articles-grid" id="articlesGrid">
            @foreach (var article in Model)
            {
                <article class="news-card" data-cat-id="@article.CategoryId">
                    @if (!string.IsNullOrEmpty(article.ImagePath))
                    {
                        <div class="card-image-wrapper">
                            <img src="@article.ImagePath" alt="@article.Title" loading="lazy" />
                        </div>
                    }

                    <div class="card-content">
                        <div class="card-meta">
                            <span class="category-badge">@article.Category?.Name</span>
                            <time datetime="@article.CreatedAt.ToString("yyyy-MM-dd")">@article.CreatedAt.ToString("dd.MM.yyyy")</time>
                        </div>

                        <h2 class="card-title">@article.Title</h2>

                        <p class="card-excerpt">
                            @(article.Content.Length > 200 ? article.Content.Substring(0, 200) + "..." : article.Content)
                        </p>

                        <a href="/Articles/Details/@article.Id" class="read-more-btn">Czytaj dalej &rarr;</a>
                    </div>
                </article>
            }
        </div>
    }
</main>
