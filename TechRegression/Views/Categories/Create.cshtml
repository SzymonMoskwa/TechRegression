@model TechRegression.Models.Category

@{
    ViewData["Title"] = "Nowa Kategoria";
}

<div class="login-container">
    <div class="login-box">
        <h2>Nowa Kategoria</h2>
        <p class="login-subtitle">Dodaj nową kategorię do bazy</p>

        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Name">Nazwa kategorii:</label>
                <input asp-for="Name" class="form-control" autocomplete="off" required />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div style="display: flex; gap: 1rem; margin-top: 2rem;">
                <button type="submit" class="btn-submit" style="flex: 1;">Zapisz</button>
                <a asp-action="Index" class="btn-submit" style="background: transparent; border: 1px solid var(--border-color); color: var(--text-muted); text-align: center; text-decoration: none; flex: 1;">Powrót</a>
            </div>
        </form>
    </div>
</div>
