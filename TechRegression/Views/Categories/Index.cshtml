@model IEnumerable<TechRegression.Models.Category>

@{
    ViewData["Title"] = "Zarządzanie Kategoriami";
}

<div class="admin-panel-container">
    <div class="admin-header-block">
        <h2>Panel Kategorii</h2>
        <a asp-action="Create" class="btn-submit">+ Nowa Kategoria</a>
    </div>

    <div class="table-responsive">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Nazwa Kategorii</th>
                    <th style="text-align: right;">Akcje</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="category-name-cell">@item.Name</td>
                        <td style="text-align: right;">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="table-link-btn">Edytuj</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="table-link-btn delete-danger">Usuń</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
