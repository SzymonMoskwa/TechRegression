@model TechRegression.Models.Category

@{
    ViewData["Title"] = "Usuwanie Kategorii";
}

<div class="login-container">
    <div class="login-box" style="border-color: #ef4444;">
        <h2 style="color: #ef4444;">Usuń Kategorię</h2>
        <p class="login-subtitle">Czy na pewno chcesz permanentnie usunąć tę kategorię?</p>

        <div class="form-group" style="margin-bottom: 2rem; padding: 1rem; background-color: #1a1a22; border: 1px solid var(--border-color);">
            <label style="margin-bottom: 0;">Wybrany obiekt:</label>
            <strong style="font-size: 1.2rem; color: var(--text-primary); display: block; margin-top: 0.5rem;">@Model.Name</strong>
        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />

            <div style="display: flex; gap: 1rem;">
                <button type="submit" class="btn-submit" style="background-color: #ef4444; color: #fff; flex: 1;">Usuń</button>
                <a asp-action="Index" class="btn-submit" style="background: transparent; border: 1px solid var(--border-color); color: var(--text-muted); text-align: center; text-decoration: none; flex: 1;">Anuluj</a>
            </div>
        </form>
    </div>
</div>
