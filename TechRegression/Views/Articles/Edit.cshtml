@model TechRegression.Models.Article
@{
    ViewData["Title"] = "Edytuj artykuł";
}

<div class="admin-panel-container edit-article-container">
    <div class="admin-header-block">
        <h2>Edycja Artykułu // ID: @Model.Id</h2>
    </div>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="CreatedAt" />
        <input type="hidden" asp-for="ImagePath" />

        <div class="form-group">
            <label asp-for="Title">Tytuł artykułu</label>
            <input asp-for="Title" class="form-control" autocomplete="off" required />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="CategoryId">Kategoria</label>
            <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.Categories" required>
                <option value="">Wybierz kategorię</option>
            </select>
            <span asp-validation-for="CategoryId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Content">Treść</label>
            <textarea asp-for="Content" class="form-control" rows="12" required></textarea>
            <span asp-validation-for="Content" class="text-danger"></span>
        </div>

        <div class="form-actions-group">
            <button type="submit" class="btn-submit">Zapisz zmiany</button>
            <a asp-action="Details" asp-route-id="@Model.Id" class="table-link-btn btn-cancel">Anuluj</a>
        </div>
    </form>
</div>
