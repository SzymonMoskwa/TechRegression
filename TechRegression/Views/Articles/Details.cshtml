@model TechRegression.Models.Article

@{
    ViewData["Title"] = Model.Title;
}

<article class="full-article">
    <header class="article-header">
        <div class="article-meta">
            <span class="category-badge">@Model.Category?.Name</span>
            <time datetime="@Model.CreatedAt.ToString("yyyy-MM-dd")">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</time>
        </div>
        <h1>@Model.Title</h1>
        @if (Context.Session.GetString("AdminLoggedIn") == "true")
        {
            <div class="admin-actions-inline" style="margin: 1rem 0 2rem 0; display: flex; gap: 0.5rem;">
                <a asp-controller="Articles" asp-action="Edit" asp-route-id="@Model.Id" class="table-link-btn">Edytuj wpis</a>
                <a asp-controller="Articles" asp-action="Delete" asp-route-id="@Model.Id" class="table-link-btn delete-danger">Usuń wpis</a>
            </div>
        }
    </header>

    @if (!string.IsNullOrEmpty(Model.ImagePath))
    {
        <div class="article-cover">
            <a href="@Model.ImagePath" target="_blank" title="Kliknij, aby otworzyć obraz w pełnej rozdzielczości">
                <img src="@Model.ImagePath" alt="@Model.Title" />
            </a>
        </div>
    }

    <div class="article-body">
        @Html.Raw(Model.Content.Replace("\r\n", "<br />").Replace("\n", "<br />"))
    </div>
</article>

<hr class="section-divider" />

<section class="comments-section">
    @if (TempData["CommentMessage"] != null)
    {
        <div class="alert @(TempData["CommentStatus"]?.ToString() == "Success" ? "alert-success" : "alert-danger")">
            @TempData["CommentMessage"]
        </div>
    }
    <h3>Dyskusja (@Model.Comments.Count)</h3>

    <div class="comment-form-container">
        <h4>Dodaj komentarz</h4>
        <form asp-controller="Comments" asp-action="Create" method="post">
            <input type="hidden" name="ArticleId" value="@Model.Id" />

            <div class="form-group">
                <label for="Author">Nick:</label>
                <input type="text" id="Author" name="Author" required class="form-control" placeholder="np. AnnoyingNerd" />
            </div>

            <div class="form-group">
                <label for="Content">Treść komentarza:</label>
                <textarea id="Content" name="Content" rows="4" required class="form-control" placeholder="Napisz, co o tym myślisz..."></textarea>
            </div>

            <button type="submit" class="btn-submit">Wyślij</button>
        </form>
    </div>

    <div class="comments-list">
        @if (!Model.Comments.Any())
        {
            <p class="no-comments">Brak komentarzy.</p>
        }
        else
        {
            @foreach (var comment in Model.Comments.OrderByDescending(c => c.CreatedAt))
            {
                <div class="comment-card">
                    <div class="comment-meta">
                        <div>
                            <span class="comment-author">@comment.Author</span>
							<span>(@comment.CreatedAt.ToString("dd.MM.yyyy HH:mm"))</span>
                        </div>

                        @if (Context.Session.GetString("AdminLoggedIn") == "true")
                        {
                            <form asp-controller="Articles" asp-action="DeleteComment" method="post" onsubmit="return confirm('Usunąć ten komentarz?');" style="margin: 0;">
                                <input type="hidden" name="commentId" value="@comment.Id" />
                                <input type="hidden" name="articleId" value="@Model.Id" />
                                <button type="submit" class="table-link-btn delete-danger" style="padding: 0.1rem 0.4rem; font-size: 0.75rem; cursor: pointer; background: transparent;">
                                    USUŃ [X]
                                </button>
                            </form>
                        }
                    </div>
                    <p class="comment-text">@comment.Content</p>
                </div>
            }
        }
    </div>
</section>
